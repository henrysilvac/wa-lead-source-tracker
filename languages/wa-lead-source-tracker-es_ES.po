msgstr "Shortcode propio"

#: includes/class-wa-ls-settings.php
msgid "CSS Selector reuses existing buttons. Shortcode creates plugin buttons."
msgstr "Selector CSS reutiliza botones existentes. Shortcode crea botones del plugin."

#: includes/class-wa-ls-settings.php
msgid "Example: .js-whatsapp-track or a[href*=\"wa.me\"]"
msgstr "Ejemplo: .js-whatsapp-track o a[href*=\"wa.me\"]"

#: includes/class-wa-ls-settings.php
msgid "Available placeholders: {channel}, {utm_source}, {utm_medium}, {utm_campaign}, {utm_content}, {utm_term}, {gclid}, {gbraid}, {wbraid}, {fbclid}, {landing_page}, {captured_at}"
